# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Specify which model to use (defaults to free Llama 3.1 8B)
# See available models at: https://openrouter.ai/models
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional: Your site info (for OpenRouter analytics)
YOUR_SITE_URL=http://localhost:3000
YOUR_SITE_NAME=Logging & Monitoring AI

# Loki Configuration
LOKI_HOST=http://127.0.0.1:3100

# Prometheus Configuration (if you add it later)
PROMETHEUS_HOST=http://localhost:9090

# Analysis Configuration
ANALYSIS_INTERVAL_MINUTES=5
LOG_ANALYSIS_LOOKBACK_MINUTES=15
